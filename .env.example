# ── Playbeat Digital Store — environment template ──
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Neon PostgreSQL connection string.
# Get it from your Neon dashboard after rotating/creating a role.
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# ── PayFast Payment Gateway (gopayfast.com) ────────────────────────────────
# Primary gateway. Get MERCHANT_ID + SECURED_KEY from the PayFast merchant
# dashboard (gopayfast.com) after merchant signup.
# When these are absent, the checkout runs in DEMO mode (auto-simulates
# a successful payment so the full flow is testable).
PAYFAST_MERCHANT_ID=""
PAYFAST_SECURED_KEY=""
PAYFAST_MERCHANT_NAME="Playbeat Digital Store"
PAYFAST_GRANT_TYPE="client_credentials"
PAYFAST_MODE="sandbox"          # "sandbox" or "production"
# Optional overrides (sensible defaults are used if left blank):
# PAYFAST_API_URL="https://sandboxapi.gopayfast.com"
# PAYFAST_CHECKOUT_URL="https://sandboxcheckout.gopayfast.com"

# ── UBL Internet Payment Gateway (legacy fallback — optional) ─────────────
# UBL_CUSTOMER_ID=""
# UBL_USERNAME=""
# UBL_PASSWORD=""
# UBL_STORE_ID="0000"
# UBL_TERMINAL_ID="0000"
# UBL_SANDBOX="true"

# ── Bank Alfalah Payment Gateway (Hosted Checkout) ────────────────────────
# Get these from Bank Alfalah merchant dashboard.
# When absent, BAFL runs in DEMO mode (simulates success).
BAFL_MERCHANT_ID=""
BAFL_STORE_ID="0000"
BAFL_MERCHANT_HASH=""
BAFL_MERCHANT_USERNAME=""
BAFL_MERCHANT_PASSWORD=""
BAFL_KEY_ONE=""              # 16-char AES-128-CBC key
BAFL_KEY_TWO=""              # 16-char AES-128-CBC IV
BAFL_SANDBOX="true"          # "true" = sandbox, "false" = production

# ── PayPal Payment Gateway (Hosted Checkout) ──────────────────────────────
# Get these from PayPal Developer Dashboard (developer.paypal.com).
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"        # "sandbox" or "live"

# ── JazzCash Payment Gateway ─────────────────────────────────────────────
# Get from jazzcash.com.pk merchant dashboard.
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
JAZZCASH_RETURN_URL="https://playbeatdigital.world/api/jazzcash/callback"
JAZZCASH_ENV="sandbox"       # "sandbox" or "production"

# ── Payrails Payment Gateway (optional) ──────────────────────────────────
# PAYRAILS_API_KEY=""
# PAYRAILS_CLIENT_ID=""
# PAYRAILS_ENV="staging"     # "staging" or "production"
