# ── Playbeat Digital Store — environment template ──
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Neon PostgreSQL connection string.
# Get it from your Neon dashboard after rotating/creating a role.
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# ── UBL Internet Payment Gateway (optional — demo mode runs when absent) ──
# Get these from UBL Digital (ubldigital.com) after merchant onboarding.
UBL_CUSTOMER_ID=""
UBL_USERNAME=""
UBL_PASSWORD=""
UBL_STORE_ID="0000"
UBL_TERMINAL_ID="0000"
# "true" = sandbox/test, "false" = live
UBL_SANDBOX="true"
