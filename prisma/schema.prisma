// Playbeat Digital Store — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  category    String
  brand       String
  price       Float
  oldPrice    Float?
  badge       String?
  icon        String
  gradient    String
  image       String?
  stock       Int      @default(100)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@index([category])
  @@index([featured])
}

model Order {
  id              String   @id @default(cuid())
  orderRef        String   @unique
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  amount          Float
  currency        String   @default("PKR")
  status          String   @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  ublOrderId      String?
  approvalCode    String?
  cardBrand       String?
  cardNumber      String?
  rawResponse     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  name      String
  category  String
  icon      String
  gradient  String
  image     String?
  price     Float
  quantity  Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model AiGeneration {
  id         String   @id @default(cuid())
  tool       String   // product-writer | blog-post | seo-meta | email-campaign | banner | customer-reply
  input      String
  output     String
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([tool])
  @@index([createdAt])
}
